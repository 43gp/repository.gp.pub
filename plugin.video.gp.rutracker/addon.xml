<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addon id="plugin.video.gp.rutracker"
       name="RuTracker"
       version="0.0.23"
       provider-name="gp@">
  <requires>
    <import addon="xbmc.python" version="3.0.1"/>
    <import addon="script.module.pysocks" optional="true"/>
    <import addon="script.module.requests" version="2.2"/>
    <import addon="plugin.video.tam" version="2.7.4"/>
    <import addon="service.locale" optional="true"/>
  </requires>
  <extension point="xbmc.python.pluginsource" library="plugin.py">
        <provides>video</provides>
  </extension>
  <extension point="xbmc.service" library="imgproxy.py" start="login" />
  <extension point="xbmc.addon.metadata">
    <news>
       v0.0.23
       Рефакторинг трейлеров, настраиваемый параметр для автоматического выбора качества трейлеров
       strip_title(): если ничего не получилось, то показываем как есть
       Первое название раздачи всегда считаем русским.
       В список стран добавлен SU:СССР
       При выводе сообщения об ошибке не пишем букву модуля.
       попроситься в search.db
    </news>
    <summary>rutracker.org browser</summary>
    <description>rutracker.org browser</description>
    <platform>all</platform>
    <license>BSD-3-Clause</license>
    <forum>https://kodi.moy.su/forum/2-81-1</forum>
    <reuselanguageinvoker>false</reuselanguageinvoker>
    <assets>
      <icon>resources/media/icon.png</icon>
    </assets>
  </extension>
</addon>
